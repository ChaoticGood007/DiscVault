generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Mold {
  id               String      @id @default(uuid())
  name             String
  brand            String
  category         String
  speed            Float
  glide            Float
  turn             Float
  fade             Float
  stability        String
  link             String?
  pic              String?
  name_slug        String?
  brand_slug       String?
  category_slug    String?
  stability_slug   String?
  color            String?
  background_color String?
  isCustom         Boolean     @default(false)
  inventory        Inventory[]
}

model DiscCollection {
  id           String      @id @default(uuid())
  name         String
  description  String?
  locationTree String      @default("[]")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  inventory    Inventory[]
}

model Inventory {
  id               String          @id @default(uuid())
  moldId           String
  collectionId     String?
  weight           Float?
  color            String?
  plastic          String?
  stamp            String?
  stampFoil        String?
  location         String?
  condition        Int?
  ink              String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userFade         Float?
  userGlide        Float?
  userTurn         Float?
  secondaryColor   String?
  secondaryPattern String?
  collection       DiscCollection? @relation(fields: [collectionId], references: [id])
  mold             Mold            @relation(fields: [moldId], references: [id])
}

model Settings {
  id             String   @id @default("global")
  accentColor    String   @default("#4f46e5")
  primaryVaultId String?
  locationTree   String   @default("[]")
  categoryColors String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
